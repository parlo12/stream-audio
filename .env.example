DB_HOST=postgres
DB_USER=rolf
DB_PASSWORD=newpassword
DB_NAME=streaming_db
DB_PORT=5432
# for local Docker Postgres:
DB_SSLMODE=disable
# --- Quotas / pause-ahead (content-service; optional, sane defaults) ---
# PAUSE_AHEAD_PAGES=60          # free books transcribe at most this far past the listener
# UPGRADE_URL=https://narrafied.com/upgrade   # shown in 429 quota responses
# Per-tier limits live in the plan_limits DB table (editable without redeploy).

# Optional DB connection-pool tuning (sane defaults if unset):
# DB_MAX_OPEN=20
# DB_MAX_IDLE=5

# --- Gateway hardening (optional; defaults shown) ---
# AUTH_RATE_PER_MIN=10        # per-IP req/min on /login,/signup,/auth/*
# AUTH_RATE_BURST=5
# MAX_PROXY_BODY_BYTES=67108864   # 64 MB inbound body cap

POSTGRES_USER=rolf
<set in deploy>=newpassword
POSTGRES_DB=streaming_db
JWT_SECRET=<set in deploy>
OPENAI_API_KEY=<set in deploy>
XI_API_KEY=<set in deploy>
<set in deploy>=<set in deploy>
MINIO_ROOT_USER=minio
<set in deploy>=newpassword
STREAM_HOST=https://narrafied.com
<set in deploy>=<set in deploy>

# --- Object storage: Cloudflare R2 (content-service; REQUIRED) ---
# content-service stores all media in R2 and streams via presigned URLs.
# It will not start without these set.
R2_ACCOUNT_ID=<set in deploy>
R2_ACCESS_KEY_ID=<set in deploy>
R2_SECRET_ACCESS_KEY=<set in deploy>
R2_BUCKET=<set in deploy>                 # e.g. narrafied-media
R2_ENDPOINT=<set in deploy>               # https://<account>.r2.cloudflarestorage.com (or derived from R2_ACCOUNT_ID)
R2_PUBLIC_BASE=<set in deploy>            # public base URL for covers (r2.dev or custom domain)

# --- Stripe (auth-service) ---
# REQUIRED for checkout: the single subscription Price ID to bill. Must match
# the intended price in Stripe + the iOS PricingConfiguration.swift.
STRIPE_PRICE_ID=<set in deploy>           # e.g. price_xxx
# STRIPE_SECRET_KEY / STRIPE_WEBHOOK_SECRET already required (see deploy notes)

# --- Social login (auth-service) ---
# Token verification fails closed: if a provider's vars are unset, that
# provider's sign-in rejects all tokens (the service still starts).
APPLE_BUNDLE_ID=com.rmhrealestate.AudioBook
GOOGLE_CLIENT_ID=<set in deploy>          # required: Google ID-token audience is checked against this
FACEBOOK_APP_ID=<set in deploy>           # required for Facebook: token must be issued for this app
FACEBOOK_APP_SECRET=<set in deploy>       # required for Facebook: used to build the app access token for debug_token
